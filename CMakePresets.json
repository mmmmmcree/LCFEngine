{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc",
      "description": "MSVC (Visual Studio) — x64-windows",
      "binaryDir": "${sourceDir}/build/build-msvc",
      "generator": "Visual Studio 18 2026",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "clang",
      "description": "Clang-CL (Ninja Multi-Config) — x64-windows",
      "binaryDir": "${sourceDir}/build/build-clang",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "gcc",
      "description": "GCC (Ninja Multi-Config, MinGW) — x64-mingw-dynamic",
      "binaryDir": "${sourceDir}/build/build-gcc",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "msvc-tests",
      "description": "MSVC, tests-only minimal build (gtest via vcpkg 'tests' feature). Skips RenderEngine/libs/examples to keep the build fast.",
      "inherits": "msvc",
      "binaryDir": "${sourceDir}/build/build-msvc-tests",
      "cacheVariables": {
        "LCF_BUILD_TESTS": "ON",
        "LCF_TESTS_ONLY": "ON",
        "VCPKG_MANIFEST_FEATURES": "containers;tests"
      }
    },
    {
      "name": "msvc-bench",
      "description": "MSVC, tests-only minimal build + performance benchmarks (google-benchmark).",
      "inherits": "msvc-tests",
      "binaryDir": "${sourceDir}/build/build-msvc-bench",
      "cacheVariables": {
        "LCF_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "clang-tests",
      "description": "Clang-CL, tests-only minimal build.",
      "inherits": "clang",
      "binaryDir": "${sourceDir}/build/build-clang-tests",
      "cacheVariables": {
        "LCF_BUILD_TESTS": "ON",
        "LCF_TESTS_ONLY": "ON",
        "VCPKG_MANIFEST_FEATURES": "containers;tests"
      }
    },
    {
      "name": "clang-bench",
      "description": "Clang-CL, tests-only minimal build + performance benchmarks.",
      "inherits": "clang-tests",
      "binaryDir": "${sourceDir}/build/build-clang-bench",
      "cacheVariables": {
        "LCF_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "gcc-tests",
      "description": "GCC, tests-only minimal build.",
      "inherits": "gcc",
      "binaryDir": "${sourceDir}/build-gcc-tests",
      "cacheVariables": {
        "LCF_BUILD_TESTS": "ON",
        "LCF_TESTS_ONLY": "ON",
        "VCPKG_MANIFEST_FEATURES": "containers;tests"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-debug",          "configurePreset": "msvc",        "configuration": "Debug" },
    { "name": "msvc-release",        "configurePreset": "msvc",        "configuration": "Release" },
    { "name": "msvc-relwithdebinfo", "configurePreset": "msvc",        "configuration": "RelWithDebInfo" },

    { "name": "clang-debug",          "configurePreset": "clang",       "configuration": "Debug" },
    { "name": "clang-release",        "configurePreset": "clang",       "configuration": "Release" },
    { "name": "clang-relwithdebinfo", "configurePreset": "clang",       "configuration": "RelWithDebInfo" },

    { "name": "gcc-debug",            "configurePreset": "gcc",         "configuration": "Debug" },
    { "name": "gcc-release",          "configurePreset": "gcc",         "configuration": "Release" },
    { "name": "gcc-relwithdebinfo",   "configurePreset": "gcc",         "configuration": "RelWithDebInfo" },

    { "name": "msvc-tests-debug",     "configurePreset": "msvc-tests",  "configuration": "Debug" },
    { "name": "msvc-tests-release",   "configurePreset": "msvc-tests",  "configuration": "Release" },
    { "name": "msvc-bench-release",   "configurePreset": "msvc-bench",  "configuration": "Release" },

    { "name": "clang-tests-debug",    "configurePreset": "clang-tests", "configuration": "Debug" },
    { "name": "clang-tests-release",  "configurePreset": "clang-tests", "configuration": "Release" },
    { "name": "clang-bench-release",  "configurePreset": "clang-bench", "configuration": "Release" },

    { "name": "gcc-tests-debug",      "configurePreset": "gcc-tests",   "configuration": "Debug" },
    { "name": "gcc-tests-release",    "configurePreset": "gcc-tests",   "configuration": "Release" }
  ]
}
